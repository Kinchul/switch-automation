# Copy to /etc/default/switch-camera-loop and adjust as needed.

SWITCH_AUTOMATION_DIR=/home/vkindschi/switch-automation
SWITCH_CAMERA_LOOP_ARGS="--width 1920 --height 1080 --fps 20"
# Optional if you want a different fallback sequence than the persisted selection:
# SWITCH_CAMERA_LOOP_ARGS="--width 1920 --height 1080 --fps 20 --default-sequence sulfura"

# Optional email notifications
# SWITCH_NOTIFY_EMAIL_TO=you@example.com
# SWITCH_NOTIFY_EMAIL_FROM=your-bot@gmail.com
# SWITCH_SMTP_HOST=smtp.gmail.com
# SWITCH_SMTP_PORT=587
# SWITCH_SMTP_USER=your-bot@gmail.com
# SWITCH_SMTP_PASSWORD=app-password-here
# SWITCH_SMTP_SSL=0
